# Vars consumed by docker-compose.yml for the Postiz container (channel connections).
# Copy to easypanel/.env and fill in, then `docker compose up -d` to apply.

# Meta app (developers.facebook.com) — powers both Facebook + Instagram Business method
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Instagram Standalone method (only needed if NOT using Facebook Business method above)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Google Cloud OAuth client — powers both YouTube and Google My Business.
# Enable on the same project: YouTube Data API v3, YouTube Analytics API, YouTube Reporting API,
# Google My Business API, My Business Account Management API, My Business Business Information API.
# NOTE: separate from the backend's own GOOGLE_CLIENT_ID (used for Google Contacts) —
# this one belongs to Postiz and must have its own redirect URIs registered.
POSTIZ_GOOGLE_CLIENT_ID=
POSTIZ_GOOGLE_CLIENT_SECRET=
